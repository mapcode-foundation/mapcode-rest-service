    "/mapcode/alphabets" : {
      "get" : {
        "tags" : [ "mapcode" ],
        "summary" : "Return a list of supported alphabets.",
        "description" : "",
        "operationId" : "getAlphabets",
        "produces" : [ "application/json", "application/xml" ],
        "parameters" : [ {
          "name" : "offset",
          "in" : "query",
          "description" : "(optional) Only return territories from a specific offset in the full list of territories. If the value is negative, the offset counts from the end of the list, rather than the start. For example, to return the last 10 items, simply specify `offset=-10`.",
          "required" : false,
          "type" : "integer",
          "default" : 0,
          "format" : "int32"
        }, {
          "name" : "count",
          "in" : "query",
          "description" : "(optional) Return at most `count` territories in the response.",
          "required" : false,
          "type" : "integer",
          "default" : 1000,
          "format" : "int32"
        } ],
        "responses" : {
          "200" : {
            "description" : "Returned a list of alphabets.",
