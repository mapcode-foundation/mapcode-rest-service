    "/mapcode/codes/{latDeg},{lonDeg}" : {
      "get" : {
        "tags" : [ "mapcode" ],
        "summary" : "Convert a latitude/longitude coordinate to one or more mapcodes.",
        "description" : "",
        "operationId" : "convertLatLonToMapcode",
        "produces" : [ "application/json", "application/xml" ],
        "parameters" : [ {
          "name" : "latDeg",
          "in" : "path",
          "description" : "Latitude in degrees. Format: [-90, 90].",
          "required" : true,
          "type" : "string",
          "maximum" : 90,
          "minimum" : -90
        }, {
          "name" : "lonDeg",
          "in" : "path",
          "description" : "Longitude in degrees. Format: [-180, 180) (other values are correctly wrapped).",
          "required" : true,
          "type" : "string",
          "maximum" : 180,
          "exclusiveMaximum" : true,
          "minimum" : -180
        }, {
          "name" : "precision",
          "in" : "query",
          "description" : "(optional) Additional precision for the mapcodes. This uses precision extension characters, which are appended to a mapcode after a `-`.",
          "required" : false,
          "type" : "string",
          "default" : "0",
          "maximum" : 8,
          "minimum" : 0
        }, {
          "name" : "territory",
          "in" : "query",
          "description" : "(optional) Limit the returned mapcodes to this territory. This is useful if the territory is already set by the context of the application (for example, you are only interested in mapcodes for your country). If omitted, mapcodes for all territories are considered.",
          "required" : false,
          "type" : "string"
        }, {
          "name" : "country",
          "in" : "query",
          "description" : "(optional) Limit the returned mapcodes to this country. This is useful if the country is already set by the context of the application (for example, you are only interested in mapcodes for your country). If omitted, mapcodes for all countries are considered.",
          "required" : false,
          "type" : "string"
        }, {
          "name" : "alphabet",
          "in" : "query",
          "description" : "(optional) Provide the strings in the response using this alphabet (as well as Roman). This allows you to retrieve mapcodes written a specific script.",
          "required" : false,
          "type" : "string"
        }, {
          "name" : "include",
          "in" : "query",
          "description" : "(optional) Provide additional information in the response. You can include: `offset` to include the distance (in meters) of the center of the mapcode area to the coordinate; `territory` to always include a territory code, even for international mapcodes; `alphabet` to always include `mapcodeInAlphabet` and `territoryInAlphabet` attributes, even for Roman; `rectangle` to include the geospatial area covered by a mapcode.",
          "required" : false,
          "type" : "string"
        } ],
        "responses" : {
          "200" : {
            "description" : "Successful conversion to mapcode.",
            "schema" : {
              "$ref" : "#/definitions/mapcodes"
            }
          },
          "400" : {
            "description" : "Bad request. For example, a parameter may be out of range."
          },
          "404" : {
            "description" : "Coordinate does not exist."
          }
        }
      }
    },
