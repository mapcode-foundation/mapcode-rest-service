  "definitions" : {
    "alphabet" : {
      "type" : "object",
      "properties" : {
        "name" : {
          "type" : "string",
          "description" : "The name of the alphabet. Currently, this is the only attribute for an alphabet."
        }
      },
      "xml" : {
        "name" : "alphabet"
      },
      "description" : "An alphabet definition object, such as returned by `GET /mapcode/alphabets/roman`."
    },
    "alphabets" : {
      "type" : "object",
      "properties" : {
        "total" : {
          "type" : "integer",
          "format" : "int32",
          "description" : "The total number of alphabet objects (not just the ones in this response)."
        },
        "alphabets" : {
          "xml" : {
            "name" : "alphabet"
          },
          "description" : "A list of alphabet objects.",
          "$ref" : "#/definitions/alphabet"
        }
      },
      "xml" : {
        "name" : "alphabets"
      },
      "description" : "A list of alphabet objects, such as returned by `GET /mapcode/alphabets`."
    },
    "mapcode" : {
      "type" : "object",
      "properties" : {
        "mapcode" : {
          "type" : "string",
          "example" : "2TNM",
          "description" : "The mapcode without the territory code. Format: 5-10 characters, including the '.'."
        },
        "mapcodeInAlphabet" : {
          "type" : "string",
          "description" : "(optional) The same mapcode in a specific alphabet. To view which alphabets are available: `GET /mapcode/alphabets`"
        },
        "territory" : {
          "type" : "string",
          "example" : "NLD",
          "description" : "The territory code. Format: `XXX` or `XX-YY`. To view which alphabets are available: `GET /mapcode/territories`"
        },
        "territoryInAlphabet" : {
          "type" : "string",
          "description" : "(optional) The same territory code in a specific alphabet."
        },
        "offsetMeters" : {
          "type" : "number",
          "format" : "double",
          "description" : "(optional) The approximated offset from the specified coordinate to the center of this mapcode area."
        },
        "rectangle" : {
          "description" : "(optional) The rectangular area covered by the mapcode.",
          "$ref" : "#/definitions/rectangle"
        }
      },
      "xml" : {
        "name" : "mapcode"
      },
      "description" : "A mapcode object, such as returned by `GET /mapcode/codes/52,5/local`."
    },
    "mapcodes" : {
      "type" : "object",
      "properties" : {
        "local" : {
          "description" : "A local mapcode. This is the shortest local mapcode which seems to best match input coordinate. Note that coordinates near borders of adjacent territories may be covered by different local mapcodes (with different territory codes). In such cases, the 'local' mapcode may not always specify the territory you would expect. The `mapcodes` attribute will contain the 'correct' local mapcode in those cases. This `local` mapcode is only offered as a convenience.",
          "$ref" : "#/definitions/mapcode"
        },
        "international" : {
          "description" : "The international mapcode. This is globally unique mapcode, which does not require a territory code. The downside of using international mapcodes is their length: they are always 10 characters.",
          "$ref" : "#/definitions/mapcode"
        },
        "mapcodes" : {
          "xml" : {
            "wrapped" : true
          },
          "description" : "The list of all alternative mapcodes for the specified coordinate. Coordinates near borders of territories may be covered by mapcodes from multiple territories and within a single territory, mapcodes of different lengths may exist. Normally, the logical thing to do, is select the shortest mapcode in the correct territory from this list. The attribute `local` tries to achieve this as well but in some cases it may use a territory you don't wish to use.",
          "$ref" : "#/definitions/mapcode"
        }
      },
      "xml" : {
        "name" : "mapcodes"
      },
      "description" : "A full coordinate to mapcode response object, such as returned by `GET /mapcode/codes/52,5`."
    },
    "point" : {
      "type" : "object",
      "properties" : {
        "latDeg" : {
          "type" : "number",
          "format" : "double",
          "description" : "The latitude (South-North) in degrees. Format: [-90, 90], 0 indicates the equator.",
          "minimum" : -90,
          "maximum" : 90
        },
        "lonDeg" : {
          "type" : "number",
          "format" : "double",
          "description" : "The longitude (West-East) in degrees. Format: [-180, 180), 0 indicates the Greenwich meridian.",
          "minimum" : -180,
          "maximum" : 180
        }
      },
      "xml" : {
        "name" : "point"
      },
      "description" : "A WGS84 coordinate, specified as a latitude and logitude."
    },
    "rectangle" : {
      "type" : "object",
      "properties" : {
        "southWest" : {
          "description" : "The South-West corner of the rectangular area.",
          "$ref" : "#/definitions/point"
        },
        "northEast" : {
          "description" : "The North-East corner of the rectangular area.",
          "$ref" : "#/definitions/point"
        },
        "center" : {
          "description" : "The center coordinate of the rectangular area.",
          "$ref" : "#/definitions/point"
        }
      },
      "xml" : {
        "name" : "rectangle"
      },
      "description" : "A rectangular geospatial area, defined by its South-West and North-East corners."
    },
    "territory" : {
      "type" : "object",
      "properties" : {
        "alphaCode" : {
          "type" : "string",
          "description" : "The alpha-code of the territory. This is a 3-character `XXX` code, or a 2-2 character `XX-YY` code, for territories which are divided into sub-regions."
        },
        "alphaCodeMinimalUnambiguous" : {
          "type" : "string",
          "description" : "The shortest alpha-code which is still unambiguous, world-wide. For example, `TX` is unambiguous, world-wide, for Texas in the USA, but `IN` is not: it can be India or Indiana, USA."
        },
        "alphaCodeMinimal" : {
          "type" : "string",
          "description" : "The shortest alpha-code. This code may be ambiguous for `XX-YY` types of codes, if used without its parent territory."
        },
        "fullName" : {
          "type" : "string",
          "description" : "The full name (in English) of the territory."
        },
        "parentTerritory" : {
          "type" : "string",
          "description" : "(optional) The full name (in English) of the parent territory. This is only relevant for `XX-YY` codes."
        },
        "aliases" : {
          "type" : "array",
          "xml" : {
            "wrapped" : true
          },
          "description" : "Alias territory codes for the territory. For example, `US-VI` and `USA-VI` both designate the Virgin Islands.",
          "items" : {
            "type" : "string"
          }
        },
        "fullNameAliases" : {
          "type" : "array",
          "xml" : {
            "wrapped" : true
          },
          "description" : "Alias names (in English) of the territory. For example, `GBR` designates the United Kingdom, but it has aliases, such as Great Britain, Scotland and more.",
          "items" : {
            "type" : "string"
          }
        },
        "alphabets" : {
          "xml" : {
            "wrapped" : true
          },
          "description" : "A list of typical alphabets (scripts) used in this territory, ordered by importance. `ROMAN` is always present in this list, as a fallback.",
          "$ref" : "#/definitions/alphabets"
        }
      },
      "xml" : {
        "name" : "territory"
      },
      "description" : "A territory definition object, such as returned by `GET /mapcode/territories/nld`."
    },
    "territoryCandidate" : {
      "type" : "object",
      "properties" : {
        "alphaCode" : {
          "type" : "string",
          "description" : "The mapcode alpha-code of the territory (3-character `XXX` or `XX-YY`)."
        },
        "parentAlphaCode" : {
          "type" : "string",
          "description" : "(optional) The mapcode alpha-code of the parent country. Omitted when not applicable."
        }
      },
      "xml" : {
        "name" : "territoryCandidate"
      },
      "description" : "A single territory candidate returned by territory lookup for a lat/lon."
    },
    "territoryCandidates" : {
      "type" : "object",
      "properties" : {
        "territories" : {
          "type" : "array",
          "xml" : {
            "name" : "territoryCandidate"
          },
          "description" : "Ranked list of territory candidates; most specific first.",
          "items" : {
            "xml" : {
              "name" : "territoryCandidate"
            },
            "$ref" : "#/definitions/territoryCandidate"
          }
        }
      },
      "xml" : {
        "name" : "territories"
      },
      "description" : "Ranked list of territory candidates for a lat/lon, as returned by `GET /mapcode/codes/{lat},{lon}/territories`."
    }
  }
}